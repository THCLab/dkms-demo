# Host IP address used by DKMS services to announce their public URL.
#
# Services advertise this address in OOBI (Out-Of-Band Introduction) records
# so that external clients can discover and connect to them.
#
# On Linux (default):
#   Use the Docker bridge gateway IP: 172.17.0.1
#   Verify with: docker network inspect bridge | grep Gateway
#
# On macOS / Windows (Docker Desktop):
#   Use host.docker.internal or your machine's LAN IP
#   e.g.: HOST_IP=host.docker.internal
#
HOST_IP=172.17.0.1
